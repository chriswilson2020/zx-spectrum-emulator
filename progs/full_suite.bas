5000 REM ARRAY CELLULAR AUTOMATON WITH HEARTBEAT
5010 CLS
5020 BORDER 0: PAPER 0: INK 7
5030 PRINT AT 0,2;"ARRAY CELLULAR AUTOMATON"
5035 PRINT AT 2,2;"HEARTBEAT / PROGRESS ENABLED"
5040 FOR y=1 TO 20
5045 PRINT AT 21,0;"INIT ROW ";y;" OF 20          "
5050 FOR x=1 TO 32
5060 LET a(y,x)=0
5070 IF RND>.72 THEN LET a(y,x)=1
5080 NEXT x
5090 NEXT y
5095 PRINT AT 21,0;"INIT COMPLETE            "
5096 PAUSE 20
5100 FOR g=1 TO 18
5105 INK 6: PRINT AT 20,0;"GENERATION ";g;" DRAWING     "
5110 FOR y=1 TO 20
5115 IF y=1 OR y=5 OR y=10 OR y=15 OR y=20 THEN PRINT AT 21,0;"GEN ";g;" DRAW ROW ";y;"        "
5120 FOR x=1 TO 32
5130 IF a(y,x)=1 THEN INK 2: PRINT AT y-1,x-1;CHR$ 144;: GO TO 5150
5140 PRINT AT y-1,x-1;" ";
5150 NEXT x
5160 NEXT y
5170 INK 6: PRINT AT 20,0;"GENERATION ";g;" CALCULATING "
5180 FOR y=2 TO 19
5185 PRINT AT 21,0;"GEN ";g;" CALC ROW ";y;"        "
5190 FOR x=2 TO 31
5200 LET n=0
5201 LET n=n+a(y-1,x-1)
5202 LET n=n+a(y-1,x)
5203 LET n=n+a(y-1,x+1)
5204 LET n=n+a(y,x-1)
5205 LET n=n+a(y,x+1)
5206 LET n=n+a(y+1,x-1)
5207 LET n=n+a(y+1,x)
5208 LET n=n+a(y+1,x+1)
5210 LET b(y,x)=0
5220 IF a(y,x)=1 AND n>1 AND n<4 THEN LET b(y,x)=1
5230 IF a(y,x)=0 AND n=3 THEN LET b(y,x)=1
5240 NEXT x
5250 NEXT y
5255 INK 6: PRINT AT 20,0;"GENERATION ";g;" COPYING     "
5260 FOR y=2 TO 19
5265 IF y=2 OR y=10 OR y=19 THEN PRINT AT 21,0;"GEN ";g;" COPY ROW ";y;"        "
5270 FOR x=2 TO 31
5280 LET a(y,x)=b(y,x)
5290 NEXT x
5300 NEXT y
5305 PRINT AT 21,0;"GEN ";g;" COMPLETE            "
5310 NEXT g
5320 GO SUB 800
5330 RETURN

