2000 REM UDG, COLOUR, ATTR, SCREEN$
2010 CLS
2020 BORDER 0: PAPER 0
2030 FOR y=0 TO 21
2040 FOR x=0 TO 31
2050 INK FN r(7)
2060 IF RND>.82 THEN PRINT AT y,x;CHR$ (143+FN r(6));: GO TO 2080
2070 PRINT AT y,x;".";
2080 NEXT x
2090 NEXT y
2100 LET x=16: LET y=11
2110 FOR t=1 TO 90
2120 LET ox=x: LET oy=y
2130 LET x=x+FN r(3)-2
2140 LET y=y+FN r(3)-2
2150 IF x<1 THEN LET x=1
2160 IF x>30 THEN LET x=30
2170 IF y<1 THEN LET y=1
2180 IF y>20 THEN LET y=20
2190 PRINT AT oy,ox;" ";
2200 INK FN r(7): BRIGHT 1
2210 PRINT AT y,x;CHR$ 147;
2220 BRIGHT 0
2230 LET q=ATTR(y,x)
2240 LET c$=SCREEN$(y,x)
2250 INK 7: PRINT AT 20,0;"X=";x;" Y=";y;" ATTR=";q;"       "
