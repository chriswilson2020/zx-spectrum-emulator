4260 LET z$=STR$ (VAL n$+99)
4270 PRINT AT 19,1;"STR$ RESULT: ";z$
4280 PRINT AT 20,1;"CHR$/CODE: ";
4290 FOR n=65 TO 74: PRINT CHR$ n;":";CODE CHR$ n;" ";: NEXT n
4295 GO SUB 800
4298 RETURN
