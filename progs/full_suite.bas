2290 GO SUB 800
2300 RETURN

3000 REM MATHS GRAPHICS: PLOT, DRAW, CIRCLE
3010 CLS
3020 BORDER 0: PAPER 0: INK 7
3030 PRINT AT 0,0;"PLOT DRAW CIRCLE SIN COS"
3040 LET lx=128: LET ly=88
3050 FOR t=0 TO 628 STEP 4
3060 LET u=t/37
3070 LET x=FN x(u)
3080 LET y=FN y(u)
3090 INK 1+INT(t/90)
3100 IF x<0 THEN LET x=0
3110 IF x>255 THEN LET x=255
3120 IF y<0 THEN LET y=0
3130 IF y>175 THEN LET y=175
3140 PLOT lx,ly
3150 DRAW x-lx,y-ly
3160 LET lx=x: LET ly=y
3170 NEXT t
3180 FOR r=8 TO 80 STEP 12
3190 INK 1+INT(r/12)
3200 CIRCLE 128,88,r
3210 NEXT r
3220 OVER 1: INK 7
3230 PLOT 0,0: DRAW 255,175
3240 PLOT 255,0: DRAW -255,175
3250 OVER 0
3260 GO SUB 800
3270 RETURN

4000 REM STRINGS, SORTING, SLICING, VAL, STR$, CHR$, CODE
4010 CLS
4020 RESTORE 4300
4030 FOR i=1 TO 12
4040 READ w$(i)
4050 NEXT i
4060 INK 6: PRINT AT 0,2;"STRING ARRAY BEFORE SORT"
4070 INK 7
4080 FOR i=1 TO 12
4090 PRINT AT 1+i,2;w$(i)
4100 NEXT i
4110 FOR i=1 TO 11
4120 FOR j=i+1 TO 12
4130 IF w$(j)<w$(i) THEN LET t$=w$(i): LET w$(i)=w$(j): LET w$(j)=t$
4140 NEXT j
4150 NEXT i
4160 INK 6: PRINT AT 0,18;"AFTER SORT"
4170 INK 7
4180 FOR i=1 TO 12
4190 PRINT AT 1+i,18;w$(i)
4200 NEXT i
